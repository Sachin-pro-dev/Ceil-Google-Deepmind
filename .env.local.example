# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real secrets (Principle 5, PRD 8.8).

# Runtime environment: "local" (in-process adapters, no Docker) or "cloud" (deploy phase).
CEIL_ENV=local
LOG_LEVEL=info
PORT=8080

# Local database: a directory path for file-backed PGlite, or "memory" for in-memory.
PGLITE_PATH=./.data/pglite

# Gemini / Interactions API — unused in Phase 1, needed from Phase 2 onward.
GEMINI_API_KEY=
IAPI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AGENT_BASE=antigravity-preview-05-2026
MODEL_FLASH=gemini-3.5-flash
MODEL_PRO=gemini-3.1-pro-preview

# Looper heartbeat (Phase 2+).
LOOPER_TICK_MS=3000

# Cloud adapters (deploy phase only).
GCP_PROJECT_ID=
