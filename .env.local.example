# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real secrets (Principle 5, PRD 8.8).

# Runtime environment: "local" (in-process adapters, no Docker) or "cloud" (deploy phase).
CEIL_ENV=local
LOG_LEVEL=info
PORT=8080

# Local database: a directory path for file-backed PGlite, or "memory" for in-memory.
PGLITE_PATH=./.data/pglite

# LLM mode: "mock" (canned output, no key/quota) or "real" (live Gemini).
LLM_MODE=mock

# Builder work engine: "gemini" (direct calls, offline-capable) or "iapi" (real Managed-Agent sandboxes).
AGENT_MODE=gemini
IAPI_TIMEOUT_MS=300000
GITHUB_REPO_URL=https://github.com/ceil/demo

# Gemini / Interactions API — required only when LLM_MODE=real.
GEMINI_API_KEY=
IAPI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AGENT_BASE=antigravity-preview-05-2026
MODEL_FLASH=gemini-3.5-flash
MODEL_PRO=gemini-3.1-pro-preview
MODEL_MANAGER=gemini-3.5-flash
MODEL_PLANNING=gemini-3.1-pro-preview
MODEL_LOOPER=gemini-3.5-flash

# Looper heartbeat (Phase 2+).
LOOPER_TICK_MS=3000

# Cloud adapters (deploy phase only).
GCP_PROJECT_ID=
